{
  "manifest_version": 3,
  "name": "VocabVault",
  "version": "1.0.0",
  "description": "Smart vocabulary saver with Vietnamese definitions.",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
